# ==========================================
# 1. C++ 编译产物 (最重要)
# ==========================================
build/
bin/
lib/
*.o
*.a
*.so
*.out
# 排除具体的 demo 二进制名
mnist_demo
benchmark

# ==========================================
# 2. CMake 缓存与临时文件
# ==========================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install/
CPackConfig.cmake
CPackSourceConfig.cmake

# ==========================================
# 3. Python 虚拟环境与缓存
# ==========================================
venv/
env/
.env
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# ==========================================
# 4. 模型文件与大数据集 (通常不建议进库)
# ==========================================
# 如果你的模型文件很大，建议排除。如果为了演示必须上传，可以加 !mnist_v2.mflow
models/*.mflow
image/*.bin
data/MNIST/
*.mflow
*.bin

# ==========================================
# 5. 编辑器与系统临时文件
# ==========================================
.vscode/
.idea/
.DS_Store
*.swp
*~
*.bak
